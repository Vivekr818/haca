# Neon PostgreSQL Configuration
# Get this value from your Neon project dashboard at https://neon.tech

# Your Neon PostgreSQL connection string
# Format: postgresql://[user]:[password]@[host]/[database]?sslmode=require
DATABASE_URL=your_neon_postgresql_connection_string

# Security Warning: DATABASE_URL should never be committed to version control
# Always use .env.local for actual credentials and ensure .env.local is in .gitignore
